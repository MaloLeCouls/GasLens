{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "gaslens hook --event post-tool-use" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "gaslens doctor --hook --quiet-when-ok" }
        ]
      }
    ]
  }
}
