{
  "name": "@malolecouls/gaslens",
  "version": "0.0.1",
  "description": "Outil CLI d'analyse de code Google Apps Script, conçu pour être consommé par un agent IA.",
  "type": "module",
  "bin": {
    "gaslens": "./bin/gaslens.js",
    "gaslens-mcp": "./bin/gaslens-mcp.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaloLeCouls/GasLens.git"
  },
  "homepage": "https://github.com/MaloLeCouls/GasLens#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan": "node ./bin/gaslens.js scan",
    "bench:scale": "node scripts/bench-scale.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "optionalDependencies": {
    "google-auth-library": "^10.7.0"
  }
}
