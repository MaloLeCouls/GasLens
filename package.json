{
  "name": "gaslens",
  "version": "0.0.1",
  "description": "Outil CLI d'analyse de code Google Apps Script, conçu pour être consommé par un agent IA.",
  "type": "module",
  "bin": {
    "gaslens": "./bin/gaslens.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan": "node ./bin/gaslens.js scan"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
